{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/how-to-calculate-your-fire-number", "destination": "/how-to-calculate-fire-number", "permanent": true },
    { "source": "/how-to-calculate-your-fire-number.html", "destination": "/how-to-calculate-fire-number", "permanent": true },
    { "source": "/rent-vs-buy-the-math", "destination": "/rent-vs-buy-math", "permanent": true },
    { "source": "/rent-vs-buy-the-math.html", "destination": "/rent-vs-buy-math", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
